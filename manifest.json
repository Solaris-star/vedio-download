{
  "manifest_version": 3,
  "name": "X/Twitter 视频下载器",
  "version": "2.0",
  "description": "在 X/Twitter 视频上添加下载按钮，点击即下最高画质 MP4",
  "permissions": ["storage", "downloads", "cookies"],
  "host_permissions": ["*://x.com/*", "*://twitter.com/*", "*://video.twimg.com/*", "*://api.twitter.com/*", "*://api.x.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}