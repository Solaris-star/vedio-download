{
  "manifest_version": 3,
  "name": "社交视频下载器",
  "version": "6.0",
  "description": "浮动按钮一键下载 X/Twitter 和小红书视频，Twitter 支持分辨率选择（1080p/720p/360p），无需登录",
  "permissions": ["downloads"],
  "host_permissions": [
    "*://x.com/*",
    "*://video.twimg.com/*",
    "*://cdn.syndication.twimg.com/*",
    "*://www.xiaohongshu.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://www.xiaohongshu.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}