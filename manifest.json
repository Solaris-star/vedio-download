{
  "manifest_version": 3,
  "name": "X/Twitter 视频下载器",
  "version": "3.0",
  "description": "浮动按钮一键下载 X/Twitter 视频最高画质 MP4，不侵入页面 DOM",
  "permissions": ["storage", "downloads", "cookies"],
  "host_permissions": ["*://x.com/*", "*://twitter.com/*", "*://video.twimg.com/*", "*://api.twitter.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}